def shefferToHuntingtonFinal : List E :=
  match Certificate.runItems shefferInitial shefferToHuntingtonItems with
  | some eqs => eqs
  | none => []

theorem shefferToHuntingtonRun :
    Certificate.runItems shefferInitial shefferToHuntingtonItems = some shefferToHuntingtonFinal := by
  native_decide

theorem shefferToHuntingtonKnown1 : Certificate.known? shefferToHuntingtonFinal huntingtonEquation1 = true := by
  native_decide
theorem shefferToHuntingtonKnown2 : Certificate.known? shefferToHuntingtonFinal huntingtonEquation2 = true := by
  native_decide
theorem shefferToHuntingtonKnown3 : Certificate.known? shefferToHuntingtonFinal huntingtonEquation3 = true := by
  native_decide

theorem shefferToHuntington_valid {alpha : Type u} (op : alpha -> alpha -> alpha)
    (hS1 : WolframBooleanCertificates.shefferEquation1.Valid op)
    (hS2 : WolframBooleanCertificates.shefferEquation2.Valid op)
    (hS3 : WolframBooleanCertificates.shefferEquation3.Valid op) :
    And (huntingtonEquation1.Valid op) (And (huntingtonEquation2.Valid op) (huntingtonEquation3.Valid op)) := by
  have hall := Certificate.runItems_sound (op := op) shefferToHuntingtonRun (by
    intro eq he
    simp [shefferInitial] at he
    rcases he with rfl | rfl | rfl
    exact hS1
    exact hS2
    exact hS3)
  exact And.intro (Certificate.known?_sound shefferToHuntingtonKnown1 hall)
    (And.intro (Certificate.known?_sound shefferToHuntingtonKnown2 hall)
      (Certificate.known?_sound shefferToHuntingtonKnown3 hall))

