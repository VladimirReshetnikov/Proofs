/-! ## Taylor partial-sum machinery (as in `A198683N12Endpoints`, higher order) -/

private theorem sin_terms_antitone {x : ℝ} (h0 : 0 ≤ x) (h1 : x ≤ 1) :
    Antitone fun i : ℕ => x ^ (2 * i + 1) / (Nat.factorial (2 * i + 1) : ℝ) := by
  apply antitone_nat_of_succ_le
  intro n
  have hp : x ^ (2 * (n + 1) + 1) ≤ x ^ (2 * n + 1) :=
    pow_le_pow_of_le_one h0 h1 (by omega)
  have hf : (Nat.factorial (2 * n + 1) : ℝ) ≤ (Nat.factorial (2 * (n + 1) + 1) : ℝ) := by
    exact_mod_cast Nat.factorial_le (by omega)
  have hd1 : (0 : ℝ) < (Nat.factorial (2 * n + 1) : ℝ) := by
    exact_mod_cast Nat.factorial_pos _
  have hd2 : (0 : ℝ) < (Nat.factorial (2 * (n + 1) + 1) : ℝ) := by
    exact_mod_cast Nat.factorial_pos _
  rw [div_le_div_iff₀ hd2 hd1]
  exact mul_le_mul hp hf hd1.le (pow_nonneg h0 _)

private theorem cos_terms_antitone {x : ℝ} (h0 : 0 ≤ x) (h1 : x ≤ 1) :
    Antitone fun i : ℕ => x ^ (2 * i) / (Nat.factorial (2 * i) : ℝ) := by
  apply antitone_nat_of_succ_le
  intro n
  have hp : x ^ (2 * (n + 1)) ≤ x ^ (2 * n) :=
    pow_le_pow_of_le_one h0 h1 (by omega)
  have hf : (Nat.factorial (2 * n) : ℝ) ≤ (Nat.factorial (2 * (n + 1)) : ℝ) := by
    exact_mod_cast Nat.factorial_le (by omega)
  have hd1 : (0 : ℝ) < (Nat.factorial (2 * n) : ℝ) := by
    exact_mod_cast Nat.factorial_pos _
  have hd2 : (0 : ℝ) < (Nat.factorial (2 * (n + 1)) : ℝ) := by
    exact_mod_cast Nat.factorial_pos _
  rw [div_le_div_iff₀ hd2 hd1]
  exact mul_le_mul hp hf hd1.le (pow_nonneg h0 _)

private theorem sin_tendsto (x : ℝ) :
    Filter.Tendsto
      (fun n => ∑ i ∈ Finset.range n,
        (-1 : ℝ) ^ i * (x ^ (2 * i + 1) / (Nat.factorial (2 * i + 1) : ℝ)))
      Filter.atTop (nhds (Real.sin x)) := by
  have h := (Real.hasSum_sin x).tendsto_sum_nat
  simpa only [mul_div_assoc] using h

private theorem cos_tendsto (x : ℝ) :
    Filter.Tendsto
      (fun n => ∑ i ∈ Finset.range n,
        (-1 : ℝ) ^ i * (x ^ (2 * i) / (Nat.factorial (2 * i) : ℝ)))
      Filter.atTop (nhds (Real.cos x)) := by
  have h := (Real.hasSum_cos x).tendsto_sum_nat
  simpa only [mul_div_assoc] using h

private theorem sin_partial_le {x : ℝ} (h0 : 0 ≤ x) (h1 : x ≤ 1) (k : ℕ) :
    ∑ i ∈ Finset.range (2 * k),
        (-1 : ℝ) ^ i * (x ^ (2 * i + 1) / (Nat.factorial (2 * i + 1) : ℝ)) ≤
      Real.sin x :=
  Antitone.alternating_series_le_tendsto (sin_tendsto x) (sin_terms_antitone h0 h1) k

private theorem le_sin_partial {x : ℝ} (h0 : 0 ≤ x) (h1 : x ≤ 1) (k : ℕ) :
    Real.sin x ≤
      ∑ i ∈ Finset.range (2 * k + 1),
        (-1 : ℝ) ^ i * (x ^ (2 * i + 1) / (Nat.factorial (2 * i + 1) : ℝ)) :=
  Antitone.tendsto_le_alternating_series (sin_tendsto x) (sin_terms_antitone h0 h1) k

private theorem cos_partial_le {x : ℝ} (h0 : 0 ≤ x) (h1 : x ≤ 1) (k : ℕ) :
    ∑ i ∈ Finset.range (2 * k),
        (-1 : ℝ) ^ i * (x ^ (2 * i) / (Nat.factorial (2 * i) : ℝ)) ≤
      Real.cos x :=
  Antitone.alternating_series_le_tendsto (cos_tendsto x) (cos_terms_antitone h0 h1) k

private theorem le_cos_partial {x : ℝ} (h0 : 0 ≤ x) (h1 : x ≤ 1) (k : ℕ) :
    Real.cos x ≤
      ∑ i ∈ Finset.range (2 * k + 1),
        (-1 : ℝ) ^ i * (x ^ (2 * i) / (Nat.factorial (2 * i) : ℝ)) :=
  Antitone.tendsto_le_alternating_series (cos_tendsto x) (cos_terms_antitone h0 h1) k

private theorem lt_sin_taylor {A q : ℝ} (h0 : 0 ≤ A) (h1 : A ≤ 1) (k : ℕ)
    (h : q < ∑ i ∈ Finset.range (2 * k),
      (-1 : ℝ) ^ i * (A ^ (2 * i + 1) / (Nat.factorial (2 * i + 1) : ℝ))) :
    q < Real.sin A :=
  h.trans_le (sin_partial_le h0 h1 k)

private theorem sin_taylor_lt {A q : ℝ} (h0 : 0 ≤ A) (h1 : A ≤ 1) (k : ℕ)
    (h : (∑ i ∈ Finset.range (2 * k + 1),
      (-1 : ℝ) ^ i * (A ^ (2 * i + 1) / (Nat.factorial (2 * i + 1) : ℝ))) < q) :
    Real.sin A < q :=
  (le_sin_partial h0 h1 k).trans_lt h

private theorem lt_cos_taylor {A q : ℝ} (h0 : 0 ≤ A) (h1 : A ≤ 1) (k : ℕ)
    (h : q < ∑ i ∈ Finset.range (2 * k),
      (-1 : ℝ) ^ i * (A ^ (2 * i) / (Nat.factorial (2 * i) : ℝ))) :
    q < Real.cos A :=
  h.trans_le (cos_partial_le h0 h1 k)

private theorem cos_taylor_lt {A q : ℝ} (h0 : 0 ≤ A) (h1 : A ≤ 1) (k : ℕ)
    (h : (∑ i ∈ Finset.range (2 * k + 1),
      (-1 : ℝ) ^ i * (A ^ (2 * i) / (Nat.factorial (2 * i) : ℝ))) < q) :
    Real.cos A < q :=
  (le_cos_partial h0 h1 k).trans_lt h

/-! ## `exp` bounds: 48-digit `exp 1` box, split bounds, direct Taylor -/

private theorem exp_one_gt_48 : ((2718281828459045235360287471352662497757247093699 : ℝ) / 1000000000000000000000000000000000000000000000000) < Real.exp 1 := by
  have h := Real.sum_le_exp_of_nonneg (by norm_num : (0:ℝ) ≤ 1) 60
  refine lt_of_lt_of_le ?_ h
  norm_num [Finset.sum_range_succ, Nat.factorial]

private theorem exp_one_lt_48 : Real.exp 1 < ((27182818284590452353602874713526624977572470937 : ℝ) / 10000000000000000000000000000000000000000000000) := by
  have h := Real.exp_bound' (by norm_num : (0:ℝ) ≤ 1) (le_refl (1:ℝ)) (n := 60) (by norm_num)
  refine lt_of_le_of_lt h ?_
  norm_num [Finset.sum_range_succ, Nat.factorial]

private theorem exp_upper_taylor {y : ℝ} (h0 : 0 ≤ y) (h1 : y ≤ 1) :
    Real.exp y ≤ (∑ m ∈ Finset.range 40, y ^ m / (Nat.factorial m : ℝ)) +
      y ^ 40 * ((40 : ℝ) + 1) / ((Nat.factorial 40 : ℝ) * (40 : ℝ)) := by
  simpa using Real.exp_bound' h0 h1 (n := 40) (by norm_num)

private theorem exp_upper_rat {y r : ℝ} (h0 : 0 ≤ y) (h1 : y ≤ 1)
    (h : (∑ m ∈ Finset.range 40, y ^ m / (Nat.factorial m : ℝ)) +
      y ^ 40 * ((40 : ℝ) + 1) / ((Nat.factorial 40 : ℝ) * (40 : ℝ)) < r) :
    Real.exp y < r :=
  (exp_upper_taylor h0 h1).trans_lt h

private theorem exp_lower_rat {A r : ℝ} (h0 : 0 ≤ A) (n : ℕ)
    (h : r < ∑ m ∈ Finset.range n, A ^ m / (Nat.factorial m : ℝ)) :
    r < Real.exp A :=
  h.trans_le (Real.sum_le_exp_of_nonneg h0 n)

private theorem exp_upper_split (k : ℕ) {y : ℝ} (h0 : 0 ≤ y) (h1 : y ≤ 1) :
    Real.exp ((k : ℝ) + y) ≤
      (((27182818284590452353602874713526624977572470937 : ℝ) / 10000000000000000000000000000000000000000000000)) ^ k *
        ((∑ m ∈ Finset.range 40, y ^ m / (Nat.factorial m : ℝ)) +
          y ^ 40 * ((40 : ℝ) + 1) / ((Nat.factorial 40 : ℝ) * (40 : ℝ))) := by
  have hsplit : Real.exp ((k : ℝ) + y) = Real.exp 1 ^ k * Real.exp y := by
    rw [← Real.exp_nat_mul, ← Real.exp_add, mul_one]
  rw [hsplit]
  exact mul_le_mul (pow_le_pow_left₀ (Real.exp_pos 1).le exp_one_lt_48.le k)
    (exp_upper_taylor h0 h1) (Real.exp_pos _).le (by positivity)

private theorem exp_lower_split (k : ℕ) {y : ℝ} (h0 : 0 ≤ y) :
    (((2718281828459045235360287471352662497757247093699 : ℝ) / 1000000000000000000000000000000000000000000000000)) ^ k *
        (∑ m ∈ Finset.range 40, y ^ m / (Nat.factorial m : ℝ)) ≤
      Real.exp ((k : ℝ) + y) := by
  have hsplit : Real.exp ((k : ℝ) + y) = Real.exp 1 ^ k * Real.exp y := by
    rw [← Real.exp_nat_mul, ← Real.exp_add, mul_one]
  rw [hsplit]
  refine mul_le_mul (pow_le_pow_left₀ (by norm_num) exp_one_gt_48.le k)
    (Real.sum_le_exp_of_nonneg h0 40) ?_ (pow_nonneg (Real.exp_pos 1).le k)
  exact Finset.sum_nonneg fun i _ => by positivity

/-! ## Monotone transport on rational boxes -/

/-- Box `π/2 · r` by rationals, given a rational box for `r > 0`. -/
private theorem pi_half_mul_mem (rL rH xL xH r : ℝ)
    (h0 : 0 < rL) (h1 : rL < r) (h2 : r < rH)
    (hxL : xL ≤ (3.141592653589793238462643383279502884197169 : ℝ) / 2 * rL)
    (hxH : (3.141592653589793238462643383279502884197170 : ℝ) / 2 * rH ≤ xH) :
    xL < Real.pi / 2 * r ∧ Real.pi / 2 * r < xH := by
  have hπL : (3.141592653589793238462643383279502884197169 : ℝ) / 2 < Real.pi / 2 := by linarith [pi_gt_d42]
  have hπH : Real.pi / 2 < (3.141592653589793238462643383279502884197170 : ℝ) / 2 := by linarith [pi_lt_d42]
  have hr : 0 < r := h0.trans h1
  constructor
  · have k1 : (3.141592653589793238462643383279502884197169 : ℝ) / 2 * rL < (3.141592653589793238462643383279502884197169 : ℝ) / 2 * r :=
      mul_lt_mul_of_pos_left h1 (by norm_num)
    have k2 : (3.141592653589793238462643383279502884197169 : ℝ) / 2 * r < Real.pi / 2 * r :=
      mul_lt_mul_of_pos_right hπL hr
    linarith
  · have k1 : Real.pi / 2 * r < (3.141592653589793238462643383279502884197170 : ℝ) / 2 * r :=
      mul_lt_mul_of_pos_right hπH hr
    have k2 : (3.141592653589793238462643383279502884197170 : ℝ) / 2 * r < (3.141592653589793238462643383279502884197170 : ℝ) / 2 * rH :=
      mul_lt_mul_of_pos_left h2 (by norm_num)
    linarith

private theorem lt_sin_of_mem {x q : ℝ} (xL : ℝ) (h1 : xL < x)
    (h2 : x ≤ (157 : ℝ) / 100) (h0 : 0 ≤ xL) (hq : q < Real.sin xL) :
    q < Real.sin x := by
  have hπ : (157 : ℝ) / 100 ≤ Real.pi / 2 := by linarith [pi_gt_d42]
  exact hq.trans (Real.sin_lt_sin_of_lt_of_le_pi_div_two (by linarith) (by linarith) h1)

private theorem sin_lt_of_mem {x q : ℝ} (xH : ℝ) (h1 : x < xH)
    (h2 : xH ≤ (157 : ℝ) / 100) (h0 : 0 ≤ x) (hq : Real.sin xH < q) :
    Real.sin x < q := by
  have hπ : (157 : ℝ) / 100 ≤ Real.pi / 2 := by linarith [pi_gt_d42]
  exact (Real.sin_lt_sin_of_lt_of_le_pi_div_two (by linarith) (by linarith) h1).trans hq

private theorem lt_cos_of_mem {x q : ℝ} (xH : ℝ) (h1 : x < xH)
    (h2 : xH ≤ (157 : ℝ) / 100) (h0 : 0 ≤ x) (hq : q < Real.cos xH) :
    q < Real.cos x := by
  have hπ : (157 : ℝ) / 100 ≤ Real.pi / 2 := by linarith [pi_gt_d42]
  have hπ2 : Real.pi / 2 ≤ Real.pi := by linarith [pi_gt_d42]
  exact hq.trans (Real.cos_lt_cos_of_nonneg_of_le_pi h0 (by linarith) h1)

private theorem cos_lt_of_mem {x q : ℝ} (xL : ℝ) (h1 : xL < x)
    (h2 : x ≤ (157 : ℝ) / 100) (h0 : 0 ≤ xL) (hq : Real.cos xL < q) :
    Real.cos x < q := by
  have hπ : (157 : ℝ) / 100 ≤ Real.pi / 2 := by linarith [pi_gt_d42]
  have hπ2 : Real.pi / 2 ≤ Real.pi := by linarith [pi_gt_d42]
  exact (Real.cos_lt_cos_of_nonneg_of_le_pi h0 (by linarith) h1).trans hq

/-- Product of two positive rational boxes. -/
private theorem mul_box {x y a b c d lo hi : ℝ}
    (hx1 : a < x) (hx2 : x < b) (hy1 : c < y) (hy2 : y < d)
    (ha : 0 < a) (hc : 0 < c) (hlo : lo ≤ a * c) (hhi : b * d ≤ hi) :
    lo < x * y ∧ x * y < hi := by
  have hy0 : 0 < y := hc.trans hy1
  have hx0 : 0 < x := ha.trans hx1
  constructor
  · have k1 : a * c < a * y := mul_lt_mul_of_pos_left hy1 ha
    have k2 : a * y < x * y := mul_lt_mul_of_pos_right hx1 hy0
    linarith
  · have k1 : x * y < x * d := mul_lt_mul_of_pos_left hy2 hx0
    have k2 : x * d < b * d := mul_lt_mul_of_pos_right hx2 (hy0.trans hy2)
    linarith

/-! ## Exact quadrant/period reduction identities -/

private theorem cos_pi_half_eq_sin_one_sub (r : ℝ) :
    Real.cos (Real.pi / 2 * r) = Real.sin (Real.pi / 2 * (1 - r)) := by
  rw [← Real.sin_pi_div_two_sub]
  congr 1
  ring

private theorem sin_pi_half_eq_cos_one_sub (r : ℝ) :
    Real.sin (Real.pi / 2 * r) = Real.cos (Real.pi / 2 * (1 - r)) := by
  rw [← Real.cos_pi_div_two_sub]
  congr 1
  ring

private theorem cos_pi_half_eq_sin_sub_three (c : ℝ) :
    Real.cos (Real.pi / 2 * c) = Real.sin (Real.pi / 2 * (c - 3)) := by
  rw [show Real.pi / 2 * (c - 3) = (Real.pi / 2 * c + Real.pi / 2) - 2 * Real.pi by ring,
    Real.sin_sub_two_pi, Real.sin_add_pi_div_two]

private theorem sin_pi_half_eq_neg_cos_sub_three (c : ℝ) :
    Real.sin (Real.pi / 2 * c) = -Real.cos (Real.pi / 2 * (c - 3)) := by
  rw [show Real.pi / 2 * (c - 3) = (Real.pi / 2 * c + Real.pi / 2) - 2 * Real.pi by ring,
    Real.cos_sub_two_pi, Real.cos_add_pi_div_two]
  ring

private theorem cos_pi_half_eq_neg_cos_sub_22 (c : ℝ) :
    Real.cos (Real.pi / 2 * c) = -Real.cos (Real.pi / 2 * (c - 22)) := by
  rw [show Real.pi / 2 * (c - 22) = (Real.pi / 2 * c + Real.pi) - (6 : ℤ) * (2 * Real.pi) by
    push_cast; ring]
  rw [Real.cos_sub_int_mul_two_pi, Real.cos_add_pi]
  ring

private theorem sin_pi_half_eq_neg_sin_sub_22 (c : ℝ) :
    Real.sin (Real.pi / 2 * c) = -Real.sin (Real.pi / 2 * (c - 22)) := by
  rw [show Real.pi / 2 * (c - 22) = (Real.pi / 2 * c + Real.pi) - (6 : ℤ) * (2 * Real.pi) by
    push_cast; ring]
  rw [Real.sin_sub_int_mul_two_pi, Real.sin_add_pi]
  ring

private theorem sin_pi_half_shift4 (x : ℝ) (K : ℤ) :
    Real.sin (Real.pi / 2 * x) = Real.sin (Real.pi / 2 * (x + 4 * K)) := by
  conv_rhs => rw [show Real.pi / 2 * (x + 4 * (K : ℝ)) =
    Real.pi / 2 * x + (K : ℝ) * (2 * Real.pi) by ring]
  rw [Real.sin_add_int_mul_two_pi]

private theorem sin_pi_half_eq_sin_two_sub (t : ℝ) :
    Real.sin (Real.pi / 2 * t) = Real.sin (Real.pi / 2 * (2 - t)) := by
  rw [← Real.sin_pi_sub]
  congr 1
  ring

/-! ## The tower's scalar skeleton -/

private def r4v : ℝ := Real.exp (-(Real.pi / 2) * rho)
private def a5v : ℝ := Real.sin (Real.pi / 2 * (1 - r4v))
private def b5v : ℝ := Real.cos (Real.pi / 2 * (1 - r4v))
private def E8v : ℝ := Real.exp (Real.pi / 2 * b5v)
private def c8v : ℝ := Real.cos (Real.pi / 2 * a5v)
private def s8v : ℝ := Real.sin (Real.pi / 2 * a5v)
private def re8v : ℝ := E8v * c8v
private def m8v : ℝ := E8v * s8v
private def E9v : ℝ := Real.exp (Real.pi / 2 * m8v)
private def p9v : ℝ := Real.sin (Real.pi / 2 * (re8v - 3))
private def q9v : ℝ := Real.cos (Real.pi / 2 * (re8v - 3))
private def re9v : ℝ := E9v * p9v
private def m9v : ℝ := E9v * q9v
private def E10v : ℝ := Real.exp (Real.pi / 2 * m9v)
private def u10v : ℝ := Real.cos (Real.pi / 2 * (re9v - 22))
private def v10v : ℝ := Real.sin (Real.pi / 2 * (re9v - 22))

/-! ## Exact complex-to-real formula lemmas -/

private theorem I_pow_re' (z : ℂ) :
    (principalPow Complex.I z).re =
      Real.exp (-(Real.pi / 2) * z.im) * Real.cos (Real.pi / 2 * z.re) := by
  dsimp [principalPow]
  rw [log_I_real, Complex.exp_re]
  rw [show ((((Real.pi / 2 : ℝ) : ℂ) * Complex.I) * z).re =
      -(Real.pi / 2) * z.im by
    simp [Complex.mul_re, Complex.mul_im]]
  rw [show ((((Real.pi / 2 : ℝ) : ℂ) * Complex.I) * z).im =
      Real.pi / 2 * z.re by
    simp [Complex.mul_re, Complex.mul_im]]

private theorem I_pow_im' (z : ℂ) :
    (principalPow Complex.I z).im =
      Real.exp (-(Real.pi / 2) * z.im) * Real.sin (Real.pi / 2 * z.re) := by
  dsimp [principalPow]
  rw [log_I_real, Complex.exp_im]
  rw [show ((((Real.pi / 2 : ℝ) : ℂ) * Complex.I) * z).re =
      -(Real.pi / 2) * z.im by
    simp [Complex.mul_re, Complex.mul_im]]
  rw [show ((((Real.pi / 2 : ℝ) : ℂ) * Complex.I) * z).im =
      Real.pi / 2 * z.re by
    simp [Complex.mul_re, Complex.mul_im]]

private theorem log_neg_I_real' :
    Complex.log (-Complex.I) = (-(Real.pi / 2 : ℝ) : ℂ) * Complex.I := by
  rw [Complex.log_neg_I]
  norm_num

private theorem neg_I_pow_re' (z : ℂ) :
    (principalPow (-Complex.I) z).re =
      Real.exp (Real.pi / 2 * z.im) * Real.cos (Real.pi / 2 * z.re) := by
  dsimp [principalPow]
  rw [log_neg_I_real', Complex.exp_re]
  simp [Complex.mul_re, Complex.mul_im, Real.cos_neg]

private theorem neg_I_pow_im' (z : ℂ) :
    (principalPow (-Complex.I) z).im =
      -(Real.exp (Real.pi / 2 * z.im) * Real.sin (Real.pi / 2 * z.re)) := by
  dsimp [principalPow]
  rw [log_neg_I_real', Complex.exp_im]
  simp [Complex.mul_re, Complex.mul_im, Real.sin_neg]

private theorem w2_eq : w2 = ((rho : ℝ) : ℂ) :=
  A198683N12Symbolic.I_pow_I_eq_q

private theorem log_w2 : Complex.log w2 = ((-(Real.pi / 2) : ℝ) : ℂ) := by
  rw [w2_eq, show rho = Real.exp (-(Real.pi / 2)) from rfl,
    ← Complex.ofReal_log (Real.exp_pos _).le]
  norm_num [Real.log_exp]

private theorem w3R_eq : w3R = -Complex.I := by
  show Complex.exp (Complex.log w2 * Complex.I) = -Complex.I
  rw [log_w2]
  apply Complex.ext
  · rw [Complex.exp_re]
    simp [Complex.mul_re, Complex.mul_im, Real.cos_pi_div_two]
  · rw [Complex.exp_im]
