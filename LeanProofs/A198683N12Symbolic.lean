-/
def nearIPowerI2161 : ℂ :=
  principalPow (principalPow q q)
    (principalPow Complex.I
      (principalPow q
        (principalPow q (principalPow q Complex.I))))

/-- Candidate `2161` in the n = 12 near-`i^i` class is exactly `i^i`. -/
theorem nearIPowerI2161_eq_q : nearIPowerI2161 = q := by
  dsimp [nearIPowerI2161]
  rw [q_pow_I_eq_neg_I]
  rw [q_pow_neg_I_eq_I]
  rw [q_pow_I_eq_neg_I]
  rw [I_pow_neg_I_eq_qInv]
  rw [q_pow_q_pow_qInv_eq_q]

/--
Representative `idx = 2378` from the n = 12 near-`i^i` probe class:

`((i^i)^((i^i)^i))^((i^(i^i))^(i^((i^i)^i)))`.
