private theorem mul_mem_neg766_neg764_of_exp_cos_bounds {e c : ‚Ñù}
    (he0 : (3723 : ‚Ñù) < e) (he1 : e < 3725)
    (hc0 : (-(257 : ‚Ñù) / 1250) < c) (hc1 : c < (-(1027 : ‚Ñù) / 5000)) :
