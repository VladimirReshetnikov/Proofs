    principalPow qInv qInv = (probeSigma : ‚ÑÇ) := by
  change Complex.exp (Complex.log qInv * qInv) = (probeSigma : ‚ÑÇ)
  rw [log_qInv]
  dsimp [qInv, probeSigma]
  rw [show (‚ÜëReal.pi / 2 : ‚ÑÇ) * ((Real.exp (Real.pi / 2) : ‚Ñù) : ‚ÑÇ) =
      (‚Üë(Real.pi / 2 * Real.exp (Real.pi / 2)) : ‚ÑÇ) by
