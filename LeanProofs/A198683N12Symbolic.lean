def nearIPowerI1901 : ℂ :=
  principalPow (principalPow q Complex.I)
    (principalPow q
      (principalPow (principalPow Complex.I q)
        (principalPow Complex.I (principalPow q Complex.I))))

/-- Candidate `1901` in the n = 12 near-`i^i` class is exactly `i^i`. -/
theorem nearIPowerI1901_eq_q : nearIPowerI1901 = q := by
  dsimp [nearIPowerI1901]
  rw [q_pow_I_eq_neg_I]
  rw [I_pow_neg_I_eq_qInv]
  rw [I_pow_q_eq_u]
  rw [u_pow_qInv_eq_I]
  rw [q_pow_I_eq_neg_I]
  rw [neg_I_pow_neg_I_eq_q]

/--
Representative `idx = 2161` from the n = 12 near-`i^i` probe class:

