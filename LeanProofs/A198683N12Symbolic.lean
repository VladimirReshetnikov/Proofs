  dsimp [probeTau]
  rw [show (-(‚ÜëReal.pi / 2) : ‚ÑÇ) * (probeSigma : ‚ÑÇ) =
      (‚Üë (-(Real.pi / 2) * probeSigma) : ‚ÑÇ) by
