import LeanProofs.A198683
import Mathlib.Analysis.SpecialFunctions.Complex.Log
import Mathlib.Analysis.SpecialFunctions.Trigonometric.Basic
import Mathlib.Tactic.NormNum
import Mathlib.Tactic.Ring

/-!
# Symbolic identities for OEIS A198683 at n = 12

The local n = 12 probe table has a 14-member class whose numerical values are
near `i^i = exp(-pi/2)`.  This module starts turning that heuristic cluster
analysis into exact Lean facts.  It also records positive-real
principal-power associativity proofs for the near-zero doubleton `{2207, 3777}`
and the retained near-one pair `{1404, 4239}`.
The identities use only principal-power reductions in the small islands
generated by `i`, `i^i`, and `i^(i^i)`.

The definitions are intentionally local to this module: `LeanProofs.A198683`
keeps most of its small-value lemmas private because they serve the direct
`n <= 7` cardinality proof there.
-/

namespace LeanProofs

namespace A198683N12Symbolic

noncomputable section

open Complex

private def rho : ŌäØ := Real.exp (-(Real.pi / 2))

private def theta : ŌäØ := Real.pi / 2 * rho

/-- The exact value of `i^i`. -/
def q : Ōäé := (rho : Ōäé)

/-- The exact value of `i^(-i)`, reciprocal to `q`. -/
def qInv : Ōäé := ((Real.exp (Real.pi / 2) : ŌäØ) : Ōäé)

/-- The exact value `i^(i^i)`. -/
def u : Ōäé := principalPow Complex.I q

/-- The reciprocal of `(i^i)^(i^i)`. -/
def qqInv : Ōäé := ((Real.exp theta : ŌäØ) : Ōäé)

/-- The exact value `i^(i^(i^i))`. -/
def v : Ōäé := principalPow Complex.I u

/-- The reciprocal-side value `(-i)^(i^(i^i))`. -/
def w : Ōäé := principalPow (-Complex.I) u

private def sigma : ŌäØ := Real.exp ((Real.pi / 2) * Real.exp (Real.pi / 2))

private def tau : ŌäØ := Real.exp (-(Real.pi / 2) * sigma)

/--
The exact positive-real subtree
`(i^((i^i)^i))^(i^((i^i)^i))`, used by two n = 12 tentative classes.
-/
def nearProbeR : Ōäé :=
  principalPow
    (principalPow Complex.I (principalPow q Complex.I))
    (principalPow Complex.I (principalPow q Complex.I))

/-- The exact tiny positive-real subtree `(i^i)^nearProbeR`. -/
def nearProbeS : Ōäé := principalPow q nearProbeR

private theorem theta_pos : 0 < theta := by
  dsimp [theta, rho]
  positivity

private theorem theta_lt_pi_div_two : theta < Real.pi / 2 := by
  dsimp [theta, rho]
  have hexp_lt_one : Real.exp (-(Real.pi / 2)) < 1 := by
    exact Real.exp_lt_one_iff.mpr (by linarith [Real.pi_pos])
  simpa using mul_lt_mul_of_pos_left hexp_lt_one (show 0 < Real.pi / 2 by positivity)

private theorem neg_pi_lt_theta : -Real.pi < theta := by
  linarith [theta_pos, Real.pi_pos]

private theorem theta_le_pi : theta Ōēż Real.pi := by
  linarith [theta_lt_pi_div_two, Real.pi_pos]

private theorem log_I_real :
    Complex.log Complex.I = ((Real.pi / 2 : ŌäØ) : Ōäé) * Complex.I := by
  rw [Complex.log_I]
  norm_num

private theorem log_q : Complex.log q = (-(Real.pi / 2) : Ōäé) := by
  dsimp [q, rho]
  rw [ŌåÉ Complex.ofReal_log (Real.exp_pos _).le, Real.log_exp]
  norm_num

private theorem log_neg_I_real :
    Complex.log (-Complex.I) = (-(Real.pi / 2 : ŌäØ) : Ōäé) * Complex.I := by
  rw [Complex.log_neg_I]
  norm_num

/-- `i^i = exp(-pi/2)`. -/
theorem I_pow_I_eq_q : principalPow Complex.I Complex.I = q := by
  dsimp [principalPow, q, rho]
  rw [log_I_real]
  rw [show (((Real.pi / 2 : ŌäØ) : Ōäé) * Complex.I) * Complex.I =
      (-(Real.pi / 2) : Ōäé) by
    apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im]]
  rw [show (-(ŌåæReal.pi / 2) : Ōäé) = Ōåæ(-(Real.pi / 2)) by norm_num]
  exact (Complex.ofReal_exp (-(Real.pi / 2))).symm

private theorem I_pow_q_eq_u : principalPow Complex.I q = u := rfl

private theorem I_pow_q_eq_exp_theta :
    principalPow Complex.I q = Complex.exp ((theta : Ōäé) * Complex.I) := by
  dsimp [principalPow, q, theta]
  rw [log_I_real]
  congr 1
  apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im, rho]

private theorem log_u : Complex.log u = (theta : Ōäé) * Complex.I := by
  dsimp [u]
  rw [I_pow_q_eq_exp_theta]
  rw [Complex.log_exp]
  ┬Ę simpa [Complex.mul_im] using neg_pi_lt_theta
  ┬Ę simpa [Complex.mul_im] using theta_le_pi

private theorem theta_mul_exp_pi_div_two :
    theta * Real.exp (Real.pi / 2) = Real.pi / 2 := by
  calc
    theta * Real.exp (Real.pi / 2)
        = Real.pi / 2 * (Real.exp (-(Real.pi / 2)) * Real.exp (Real.pi / 2)) := by
            dsimp [theta, rho]
            ring
    _ = Real.pi / 2 * 1 := by
            rw [ŌåÉ Real.exp_add]
            rw [show -(Real.pi / 2) + Real.pi / 2 = 0 by ring]
            rw [Real.exp_zero]
    _ = Real.pi / 2 := by ring

private theorem exp_pi_div_two_gt_24_div_5 :
    (24 : ŌäØ) / 5 < Real.exp (Real.pi / 2) := by
  have hpi : (157 : ŌäØ) / 100 < Real.pi / 2 := by
    linarith [Real.pi_gt_d2]
  have hsum_le :
      (Ōłæ i Ōłł Finset.range 7, ((157 : ŌäØ) / 100) ^ i / (i.factorial : ŌäØ)) Ōēż
        Real.exp ((157 : ŌäØ) / 100) :=
    Real.sum_le_exp_of_nonneg (by norm_num) 7
  have hsum_gt :
      (24 : ŌäØ) / 5 <
        Ōłæ i Ōłł Finset.range 7, ((157 : ŌäØ) / 100) ^ i / (i.factorial : ŌäØ) := by
    norm_num [Finset.sum_range_succ]
  exact hsum_gt.trans_le (hsum_le.trans ((Real.exp_le_exp).2 hpi.le))

private theorem exp_pi_div_two_mul_rho :
    Real.exp (Real.pi / 2) * rho = 1 := by
  dsimp [rho]
  rw [ŌåÉ Real.exp_add]
  rw [show Real.pi / 2 + -(Real.pi / 2) = 0 by ring]
  rw [Real.exp_zero]

private theorem neg_pi_div_two_exp_mul_rho :
    (-(Real.pi / 2) * Real.exp (Real.pi / 2)) * rho = -(Real.pi / 2) := by
  calc
    (-(Real.pi / 2) * Real.exp (Real.pi / 2)) * rho =
        -(Real.pi / 2) * (Real.exp (Real.pi / 2) * rho) := by ring
    _ = -(Real.pi / 2) * 1 := by rw [exp_pi_div_two_mul_rho]
    _ = -(Real.pi / 2) := by ring

private theorem theta_lt_one_div_three : theta < (1 : ŌäØ) / 3 := by
  have hpi : Real.pi / 2 < (63 : ŌäØ) / 40 := by
    linarith [Real.pi_lt_d2]
  have hexp_pos : 0 < Real.exp (Real.pi / 2) := Real.exp_pos _
  nlinarith [hpi, exp_pi_div_two_gt_24_div_5, theta_mul_exp_pi_div_two, theta_pos,
    hexp_pos]

private theorem exp_neg_theta_mul_exp_theta :
    Real.exp (-theta) * Real.exp theta = 1 := by
  rw [ŌåÉ Real.exp_add]
  rw [show -theta + theta = 0 by ring]
  rw [Real.exp_zero]

private theorem exp_theta_mul_exp_neg_theta :
    Real.exp theta * Real.exp (-theta) = 1 := by
  rw [ŌåÉ Real.exp_add]
  rw [show theta + -theta = 0 by ring]
  rw [Real.exp_zero]

private theorem neg_pi_div_two_exp_neg_theta_mul_exp_theta :
    (-(Real.pi / 2) * Real.exp (-theta)) * Real.exp theta = -(Real.pi / 2) := by
  calc
    (-(Real.pi / 2) * Real.exp (-theta)) * Real.exp theta =
        -(Real.pi / 2) * (Real.exp (-theta) * Real.exp theta) := by ring
    _ = -(Real.pi / 2) * 1 := by rw [exp_neg_theta_mul_exp_theta]
    _ = -(Real.pi / 2) := by ring

private theorem neg_pi_div_two_exp_theta_mul_exp_neg_theta :
    (-(Real.pi / 2) * Real.exp theta) * Real.exp (-theta) = -(Real.pi / 2) := by
  calc
    (-(Real.pi / 2) * Real.exp theta) * Real.exp (-theta) =
        -(Real.pi / 2) * (Real.exp theta * Real.exp (-theta)) := by ring
    _ = -(Real.pi / 2) * 1 := by rw [exp_theta_mul_exp_neg_theta]
    _ = -(Real.pi / 2) := by ring

private theorem u_im_eq_sin_theta : u.im = Real.sin theta := by
  rw [ŌåÉ I_pow_q_eq_u, I_pow_q_eq_exp_theta]
  simp [Complex.exp_im, Complex.mul_re, Complex.mul_im]

private theorem u_im_pos : 0 < u.im := by
  rw [u_im_eq_sin_theta]
  exact Real.sin_pos_of_pos_of_lt_pi theta_pos (by linarith [theta_lt_pi_div_two, Real.pi_pos])

private theorem pi_div_two_mul_sin_theta_lt_log_two :
    Real.pi / 2 * Real.sin theta < Real.log 2 := by
  have hsin_lt_theta : Real.sin theta < theta := Real.sin_lt theta_pos
  have harg_lt_pi_div_six : Real.pi / 2 * Real.sin theta < Real.pi / 6 := by
    nlinarith [Real.pi_pos, u_im_pos, u_im_eq_sin_theta, hsin_lt_theta,
      theta_lt_one_div_three]
  have hpi_div_six_lt_log_two : Real.pi / 6 < Real.log 2 := by
    nlinarith [Real.pi_lt_d2, Real.log_two_gt_d9]
  exact harg_lt_pi_div_six.trans hpi_div_six_lt_log_two

private theorem exp_lt_two_of_lt_log_two {x : ŌäØ} (hx : x < Real.log 2) :
    Real.exp x < 2 := by
  have h := Real.exp_lt_exp.mpr hx
  rwa [Real.exp_log (by norm_num : (0 : ŌäØ) < 2)] at h

/-- `(i^(i^i))^(i^(-i)) = i`. -/
theorem u_pow_qInv_eq_I : principalPow u qInv = Complex.I := by
  dsimp [principalPow, qInv]
  rw [log_u]
  rw [show ((theta : Ōäé) * Complex.I) * ((Real.exp (Real.pi / 2) : ŌäØ) : Ōäé) =
      ((Real.pi / 2 : ŌäØ) : Ōäé) * Complex.I by
    rw [show ((theta : Ōäé) * Complex.I) * ((Real.exp (Real.pi / 2) : ŌäØ) : Ōäé) =
        ((theta * Real.exp (Real.pi / 2) : ŌäØ) : Ōäé) * Complex.I by
      apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im]]
    rw [theta_mul_exp_pi_div_two]]
  rw [Complex.exp_mul_I]
  apply Complex.ext <;> simp

/-- `(i^(i^i))^(-i) = exp(theta)`, the reciprocal of `(i^i)^(i^i)`. -/
theorem u_pow_neg_I_eq_qqInv : principalPow u (-Complex.I) = qqInv := by
  dsimp [principalPow, qqInv]
  rw [log_u]
  rw [show ((theta : Ōäé) * Complex.I) * -Complex.I = (theta : Ōäé) by
    apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im]]
  exact (Complex.ofReal_exp theta).symm

/-- `(i^i)^i = -i`. -/
theorem q_pow_I_eq_neg_I : principalPow q Complex.I = -Complex.I := by
  dsimp [principalPow]
  rw [log_q]
  rw [show (-(ŌåæReal.pi / 2) : Ōäé) = (Ōåæ(-(Real.pi / 2)) : Ōäé) by norm_num]
  rw [Complex.exp_mul_I]
  apply Complex.ext <;> simp

/-- `i^(-i) = exp(pi/2)`. -/
theorem I_pow_neg_I_eq_qInv : principalPow Complex.I (-Complex.I) = qInv := by
  dsimp [principalPow, qInv]
  rw [log_I_real]
  rw [show (((Real.pi / 2 : ŌäØ) : Ōäé) * Complex.I) * -Complex.I =
      ((Real.pi / 2 : ŌäØ) : Ōäé) by
    apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im]]
  exact (Complex.ofReal_exp (Real.pi / 2)).symm

/-- `(i^i)^(-i) = i`. -/
theorem q_pow_neg_I_eq_I : principalPow q (-Complex.I) = Complex.I := by
  dsimp [principalPow]
  rw [log_q]
  rw [show (-(ŌåæReal.pi / 2) : Ōäé) = (Ōåæ(-(Real.pi / 2)) : Ōäé) by norm_num]
  rw [show (Ōåæ(-(Real.pi / 2)) : Ōäé) * -Complex.I =
      ((Real.pi / 2 : ŌäØ) : Ōäé) * Complex.I by
    apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im]]
  rw [Complex.exp_mul_I]
  apply Complex.ext <;> simp

/-- `(-i)^(-i) = exp(-pi/2) = i^i`. -/
theorem neg_I_pow_neg_I_eq_q : principalPow (-Complex.I) (-Complex.I) = q := by
  dsimp [principalPow, q, rho]
  rw [log_neg_I_real]
  rw [show (((-(Real.pi / 2 : ŌäØ) : Ōäé) * Complex.I) * -Complex.I) =
      (-(Real.pi / 2) : Ōäé) by
    apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im]]
  rw [show (-(ŌåæReal.pi / 2) : Ōäé) = Ōåæ(-(Real.pi / 2)) by norm_num]
  exact (Complex.ofReal_exp (-(Real.pi / 2))).symm

private theorem q_pow_q_eq_exp_neg_theta :
    principalPow q q = (Real.exp (-theta) : Ōäé) := by
  dsimp [principalPow]
  rw [log_q]
  rw [show (-(ŌåæReal.pi / 2) : Ōäé) * q = Ōåæ(-theta) by
    apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im, q, theta]]
  exact (Complex.ofReal_exp (-theta)).symm

private theorem log_q_pow_q :
    Complex.log (principalPow q q) = (-theta : Ōäé) := by
  rw [q_pow_q_eq_exp_neg_theta]
  rw [ŌåÉ Complex.ofReal_log (Real.exp_pos _).le, Real.log_exp]
  norm_num

/-- `((i^i)^(i^i))^(i^(-i)) = i^i`. -/
theorem q_pow_q_pow_qInv_eq_q :
    principalPow (principalPow q q) qInv = q := by
  change Complex.exp (Complex.log (principalPow q q) * qInv) = q
  rw [log_q_pow_q]
  rw [show ((-theta : Ōäé) * qInv) =
      (-(theta * Real.exp (Real.pi / 2)) : Ōäé) by
    dsimp [qInv]
    apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im]]
  rw [show (-(Ōåætheta * Ōåæ(Real.exp (Real.pi / 2))) : Ōäé) =
      (Ōåæ(-(theta * Real.exp (Real.pi / 2))) : Ōäé) by norm_num]
  rw [theta_mul_exp_pi_div_two]
  dsimp [q, rho]
  exact (Complex.ofReal_exp (-(Real.pi / 2))).symm

private theorem q_pow_qInv_eq_exp :
    principalPow q qInv =
      (Real.exp (-(Real.pi / 2) * Real.exp (Real.pi / 2)) : Ōäé) := by
  dsimp [principalPow]
  rw [log_q]
  rw [show (-(ŌåæReal.pi / 2) : Ōäé) * qInv =
      (Ōåæ(-(Real.pi / 2) * Real.exp (Real.pi / 2)) : Ōäé) by
    dsimp [qInv]
    apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im]]
  exact (Complex.ofReal_exp (-(Real.pi / 2) * Real.exp (Real.pi / 2))).symm

private theorem log_q_pow_qInv :
    Complex.log (principalPow q qInv) =
      (Ōåæ(-(Real.pi / 2) * Real.exp (Real.pi / 2)) : Ōäé) := by
  rw [q_pow_qInv_eq_exp]
  rw [ŌåÉ Complex.ofReal_log (Real.exp_pos _).le, Real.log_exp]

/-- `((i^i)^(i^(-i)))^(i^i) = i^i`. -/
theorem q_pow_qInv_pow_q_eq_q :
    principalPow (principalPow q qInv) q = q := by
  change Complex.exp (Complex.log (principalPow q qInv) * q) = q
  rw [log_q_pow_qInv]
  rw [show (Ōåæ(-(Real.pi / 2) * Real.exp (Real.pi / 2)) : Ōäé) * q =
      (Ōåæ((-(Real.pi / 2) * Real.exp (Real.pi / 2)) * rho) : Ōäé) by
    apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im, q]]
  rw [neg_pi_div_two_exp_mul_rho]
  dsimp [q, rho]
  exact (Complex.ofReal_exp (-(Real.pi / 2))).symm

private theorem q_pow_qq_eq_exp :
    principalPow q (principalPow q q) =
      (Real.exp (-(Real.pi / 2) * Real.exp (-theta)) : Ōäé) := by
  change Complex.exp (Complex.log q * principalPow q q) =
    (Real.exp (-(Real.pi / 2) * Real.exp (-theta)) : Ōäé)
  rw [q_pow_q_eq_exp_neg_theta]
  rw [log_q]
  rw [show (-(ŌåæReal.pi / 2) : Ōäé) * ((Real.exp (-theta) : ŌäØ) : Ōäé) =
      (Ōåæ(-(Real.pi / 2) * Real.exp (-theta)) : Ōäé) by
    apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im]]
  exact (Complex.ofReal_exp (-(Real.pi / 2) * Real.exp (-theta))).symm

private theorem log_q_pow_qq :
    Complex.log (principalPow q (principalPow q q)) =
      (Ōåæ(-(Real.pi / 2) * Real.exp (-theta)) : Ōäé) := by
  rw [q_pow_qq_eq_exp]
  rw [ŌåÉ Complex.ofReal_log (Real.exp_pos _).le, Real.log_exp]

/-- `(i^i)^((i^i)^(i^i))`, raised to `(i^(i^i))^(-i)`, is `i^i`. -/
theorem q_pow_qq_pow_qqInv_eq_q :
    principalPow (principalPow q (principalPow q q)) qqInv = q := by
  change Complex.exp (Complex.log (principalPow q (principalPow q q)) * qqInv) = q
  rw [log_q_pow_qq]
  rw [show (Ōåæ(-(Real.pi / 2) * Real.exp (-theta)) : Ōäé) * qqInv =
      (Ōåæ((-(Real.pi / 2) * Real.exp (-theta)) * Real.exp theta) : Ōäé) by
    dsimp [qqInv]
    apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im]]
  rw [neg_pi_div_two_exp_neg_theta_mul_exp_theta]
  dsimp [q, rho]
  exact (Complex.ofReal_exp (-(Real.pi / 2))).symm

private theorem q_pow_qqInv_eq_exp :
    principalPow q qqInv =
      (Real.exp (-(Real.pi / 2) * Real.exp theta) : Ōäé) := by
  dsimp [principalPow]
  rw [log_q]
  rw [show (-(ŌåæReal.pi / 2) : Ōäé) * qqInv =
      (Ōåæ(-(Real.pi / 2) * Real.exp theta) : Ōäé) by
    dsimp [qqInv]
    apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im]]
  exact (Complex.ofReal_exp (-(Real.pi / 2) * Real.exp theta)).symm

private theorem log_q_pow_qqInv :
    Complex.log (principalPow q qqInv) =
      (Ōåæ(-(Real.pi / 2) * Real.exp theta) : Ōäé) := by
  rw [q_pow_qqInv_eq_exp]
  rw [ŌåÉ Complex.ofReal_log (Real.exp_pos _).le, Real.log_exp]

/-- `(i^i)^((i^(i^i))^(-i))`, raised to `(i^i)^(i^i)`, is `i^i`. -/
theorem q_pow_qqInv_pow_qq_eq_q :
    principalPow (principalPow q qqInv) (principalPow q q) = q := by
  change Complex.exp (Complex.log (principalPow q qqInv) * principalPow q q) = q
  rw [log_q_pow_qqInv]
  rw [q_pow_q_eq_exp_neg_theta]
  rw [show (Ōåæ(-(Real.pi / 2) * Real.exp theta) : Ōäé) * ((Real.exp (-theta) : ŌäØ) : Ōäé) =
      (Ōåæ((-(Real.pi / 2) * Real.exp theta) * Real.exp (-theta)) : Ōäé) by
    apply Complex.ext <;> simp [Complex.mul_re, Complex.mul_im]]
  rw [neg_pi_div_two_exp_theta_mul_exp_neg_theta]
  dsimp [q, rho]
  exact (Complex.ofReal_exp (-(Real.pi / 2))).symm

private theorem v_mul_w_eq_one : v * w = 1 := by
  dsimp [v, w, principalPow]
  rw [log_I_real, log_neg_I_real]
  rw [ŌåÉ Complex.exp_add]
  rw [show (((Real.pi / 2 : ŌäØ) : Ōäé) * Complex.I) * u +
      (((-(Real.pi / 2 : ŌäØ) : Ōäé) * Complex.I) * u) = 0 by ring]
  exact Complex.exp_zero

private theorem w_mul_v_eq_one : w * v = 1 := by
  rw [mul_comm, v_mul_w_eq_one]

private theorem v_norm_lt_one : ŌĆ¢vŌĆ¢ < 1 := by
  dsimp [v, principalPow]
  rw [log_I_real, Complex.norm_exp]
  rw [show ((((Real.pi / 2 : ŌäØ) : Ōäé) * Complex.I) * u).re =
      -(Real.pi / 2) * u.im by
    simp [Complex.mul_re, Complex.mul_im]]
  exact Real.exp_lt_one_iff.mpr (by nlinarith [Real.pi_pos, u_im_pos])

private theorem w_norm_lt_two : ŌĆ¢wŌĆ¢ < 2 := by
  dsimp [w, principalPow]
  rw [log_neg_I_real, Complex.norm_exp]
  rw [show ((((-(Real.pi / 2 : ŌäØ) : Ōäé) * Complex.I) * u).re) =
      Real.pi / 2 * u.im by
    simp [Complex.mul_re, Complex.mul_im]]
  rw [u_im_eq_sin_theta]
  exact exp_lt_two_of_lt_log_two pi_div_two_mul_sin_theta_lt_log_two

private theorem abs_v_im_lt_one : |v.im| < 1 :=
  (Complex.abs_im_le_norm v).trans_lt v_norm_lt_one

private theorem abs_w_im_lt_two : |w.im| < 2 :=
  (Complex.abs_im_le_norm w).trans_lt w_norm_lt_two

private theorem log_q_pow_v :
    Complex.log (principalPow q v) = Complex.log q * v := by
  change Complex.log (Complex.exp (Complex.log q * v)) = Complex.log q * v
  rw [Complex.log_exp]
  ┬Ę rw [log_q]
    simp [Complex.mul_im]
    nlinarith [Real.pi_pos, (abs_lt.mp abs_v_im_lt_one).1,
      (abs_lt.mp abs_v_im_lt_one).2]
  ┬Ę rw [log_q]
    simp [Complex.mul_im]
    nlinarith [Real.pi_pos, (abs_lt.mp abs_v_im_lt_one).1,
      (abs_lt.mp abs_v_im_lt_one).2]

private theorem log_q_pow_w :
    Complex.log (principalPow q w) = Complex.log q * w := by
  change Complex.log (Complex.exp (Complex.log q * w)) = Complex.log q * w
  rw [Complex.log_exp]
  ┬Ę rw [log_q]
    simp [Complex.mul_im]
    nlinarith [Real.pi_pos, (abs_lt.mp abs_w_im_lt_two).1,
      (abs_lt.mp abs_w_im_lt_two).2]
  ┬Ę rw [log_q]
