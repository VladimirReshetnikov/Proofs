theorem BProv_Ax_s_subst_betaDiv2BitAt_of_betaDiv2BitTermAt
    {G : List Formula} {σ : Nat → Term} {bit code step idx : Nat}
    (hbit : BProv Ax_s G
      (betaDiv2BitTermAt
