    rcases h k hk with ⟨cur, next, bit, hdiv⟩
    rcases hdiv with ⟨hcur, hnext, hbit, hvalue⟩
    apply (betaDiv2StepWitnessAt_nat (scons k e) (code+1) (step+1) 0).mpr
