      have hnextTerm : BProv Ax_s C
          (betaTermTermAt (Term.var 0) code2 step2 (Term.succ idx2)) :=
        BProv_andE1 htailTerm
      have hdivTerm : BProv Ax_s C
          (div2StepTermAt (Term.var 1) (Term.var 0) bit2) :=
        BProv_andE2 htailTerm
