      (fun f hf => sentence_ax_s (f := f) hf) h2S (by
        simpa [S, body1, betaTermAt, body2, rename, Term.rename,
          SetTheory.up, Term.rename_comp, term_rename_up_succ_rename_succ,
          List.map_map, Function.comp_def] using hopen2)
