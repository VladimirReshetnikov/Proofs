          (subst (Term.upSubst (Term.upSubst σ))
            (betaAt 1 (code+2) (step+2) (idx+2))) := by
        simpa [bit2, code2, step2, idx2, bitTerm, codeTerm, stepTerm,
          idxTerm, Term.subst, Term.upSubst, Term.rename] using
