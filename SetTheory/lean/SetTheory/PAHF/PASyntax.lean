      (G := (strictHighOddLowDoubleSuccCarryContext highHalf lowHalf).map
        (rename Nat.succ))
      (highHalf := highHalf) (lowHalf := lowHalf)
      (by simpa [strictHighOddLowDoubleOpenedIHContext] using hpred))

