        simpa [strictHighDoubleLowOddSuccComponentContext,
          strictHighDoubleLowOddSuccStepsFormula, Nat.add_assoc] using hsteps)
      (by
        simpa [strictHighDoubleLowOddSuccComponentContext,
          strictHighDoubleLowOddSuccBitExFormula, Nat.add_assoc] using hbitEx)
