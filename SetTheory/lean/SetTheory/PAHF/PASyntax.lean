        (Term.succ idxTerm)) :=
    BProv_Ax_s_betaDiv2StepsThroughTermAt_step_succ_termIdx_of_leTerm
      hsteps hle
  have holdTerm : BProv Ax_s G
      (betaDiv2StepWitnessTermAt
        (Term.var oldCode) (Term.var oldStep) (Term.succ idxTerm)) :=
