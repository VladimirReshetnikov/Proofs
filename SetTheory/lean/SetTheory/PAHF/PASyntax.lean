        div2StepAt, boolAt, zeroAt, oneAt, eqConstAt, betaModTerm,
        subst, instTerm, Term.subst, Term.upSubst, rename, Term.rename,
        SetTheory.up, Term.rename_comp, term_rename_up_succ_rename_succ,
