theorem BProv_Ax_s_add_cancel_left_all (y z : Term) :
    BProv Ax_s []
      (all
        (imp
          (eq
            (Term.add (Term.var 0) (Term.rename Nat.succ y))
            (Term.add (Term.var 0) (Term.rename Nat.succ z)))
          (eq (Term.rename Nat.succ y) (Term.rename Nat.succ z)))) := by
