def wolframToShefferFinal : List E :=
  match Certificate.runItems wolframInitial wolframToShefferItems with
  | some eqs => eqs
  | none => []

theorem wolframToShefferRun :
    Certificate.runItems wolframInitial wolframToShefferItems = some wolframToShefferFinal := by
  native_decide

theorem wolframToShefferKnown1 : Certificate.known? wolframToShefferFinal shefferEquation1 = true := by
  native_decide
theorem wolframToShefferKnown2 : Certificate.known? wolframToShefferFinal shefferEquation2 = true := by
  native_decide
theorem wolframToShefferKnown3 : Certificate.known? wolframToShefferFinal shefferEquation3 = true := by
  native_decide

theorem wolframToSheffer_valid {alpha : Type u} (op : alpha -> alpha -> alpha)
    (hW : wolframEquation.Valid op) :
    And (shefferEquation1.Valid op) (And (shefferEquation2.Valid op) (shefferEquation3.Valid op)) := by
  have hall := Certificate.runItems_sound (op := op) wolframToShefferRun (by
    intro eq he
    simp [wolframInitial] at he
    rcases he with rfl
    exact hW)
  exact And.intro (Certificate.known?_sound wolframToShefferKnown1 hall)
    (And.intro (Certificate.known?_sound wolframToShefferKnown2 hall)
      (Certificate.known?_sound wolframToShefferKnown3 hall))

def meredithToWolframFinal : List E :=
  match Certificate.runItems meredithInitial meredithToWolframItems with
  | some eqs => eqs
  | none => []

theorem meredithToWolframRun :
    Certificate.runItems meredithInitial meredithToWolframItems = some meredithToWolframFinal := by
  native_decide

theorem meredithToWolframKnown : Certificate.known? meredithToWolframFinal wolframEquation = true := by
  native_decide

theorem meredithToWolfram_valid {alpha : Type u} (op : alpha -> alpha -> alpha)
    (hM1 : meredithEquation1.Valid op) (hM2 : meredithEquation2.Valid op) :
    wolframEquation.Valid op := by
  have hall := Certificate.runItems_sound (op := op) meredithToWolframRun (by
    intro eq he
    simp [meredithInitial] at he
    rcases he with rfl | rfl
    exact hM1
    exact hM2)
  exact Certificate.known?_sound meredithToWolframKnown hall

