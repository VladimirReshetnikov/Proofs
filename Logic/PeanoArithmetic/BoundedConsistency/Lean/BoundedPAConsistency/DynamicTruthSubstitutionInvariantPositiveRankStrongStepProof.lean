import BoundedPAConsistency.DynamicTruthSubstitutionInvariantPositiveRankStrongStep
import BoundedPAConsistency.ModelCodedPredicateEqualityQuotient
import BoundedPAConsistency.FinFunext

/-!
# Fixed-source proof of the positive substitution strong step

The constructor theorem lives in a semantic interface so it can be reviewed
without expanding the large fixed source formulas.  This module performs the
separate packaging step: first-order completeness turns that uniform semantic
argument into the exact lifted-PA derivation requested by
`SourceValidDomainStep`.  The existing off-domain derivation can then combine
the two branches without changing the represented induction pipeline.
-/

namespace LeanProofs.BoundedPAConsistency.DynamicTruthSubstitutionInvariantPositiveRankStrongStepProof

open LO FirstOrder
open LO.FirstOrder.Arithmetic
open LO.FirstOrder.Arithmetic.Bootstrapping
open LeanProofs.BoundedPAConsistency.CodedHierarchy
open LeanProofs.BoundedPAConsistency.OrientedHierarchy
open LeanProofs.BoundedPAConsistency.FixedLevelTruth
open LeanProofs.BoundedPAConsistency.DynamicTruthFormula
open LeanProofs.BoundedPAConsistency.DynamicTruthLocalProjectionTemplate
open LeanProofs.BoundedPAConsistency.DynamicTruthMemberValidityTemplate
open LeanProofs.BoundedPAConsistency.DynamicTruthUniversalLeafTemplate
open LeanProofs.BoundedPAConsistency.DynamicTruthQuantifierFreeAnchor
open LeanProofs.BoundedPAConsistency.DynamicTruthCrossLevelFormula
open LeanProofs.BoundedPAConsistency.DynamicTruthSubstitutionInvariantFormula
open LeanProofs.BoundedPAConsistency.DynamicTruthCrossLevelStrongStepSource
open LeanProofs.BoundedPAConsistency.DynamicTruthSubstitutionInvariantStrongStepSource
open LeanProofs.BoundedPAConsistency.DynamicTruthSubstitutionInvariantPositiveRankStrongStep
open LeanProofs.BoundedPAConsistency.ModelCodedPredicateTemplate
open LeanProofs.BoundedPAConsistency.ModelCodedPredicateParameters
open LeanProofs.BoundedPAConsistency.ModelCodedPredicateEqualityQuotient

/-! ## Focused semantic normalization of the fixed source syntax -/

section SourceSemantics

variable {M : Type*}
variable [sourceStructure :
  Structure DynamicTruthTemplateFormula.SourceLanguage M]
variable [Nonempty M] [ORingStructure M]
variable [hPA : M↓[ℒₒᵣ] ⊧* Peano]

omit [Nonempty M] hPA in
/-- In a canonical equality model supplied by the quotient helper, the
arithmetic summand of the expanded source structure is the standard
arithmetic structure generated by its `ORingStructure`. -/
private theorem sourceArithmeticReduct_eq_standardModel
    [Structure.ORing DynamicTruthTemplateFormula.SourceLanguage M] :
    sourceStructure.lMap (arithmeticHom 3 2) =
      LO.FirstOrder.Arithmetic.standardModel M := by
  letI : Structure ℒₒᵣ M :=
    sourceStructure.lMap (arithmeticHom 3 2)
  letI : Structure.ORing ℒₒᵣ M := {
    zero := by
      calc
        (@Semiterm.Operator.Zero.zero ℒₒᵣ _).val ![] =
            (@Semiterm.Operator.Zero.zero
              DynamicTruthTemplateFormula.SourceLanguage _).val ![] := by
          simp only [Semiterm.Operator.val,
            Semiterm.Operator.Zero.term_eq, Semiterm.val_func]
          congr 1
          funext i
          exact i.elim0
        _ = (0 : M) := Structure.Zero.zero
          (L := DynamicTruthTemplateFormula.SourceLanguage) (M := M)
    one := by
      calc
        (@Semiterm.Operator.One.one ℒₒᵣ _).val ![] =
            (@Semiterm.Operator.One.one
              DynamicTruthTemplateFormula.SourceLanguage _).val ![] := by
          simp only [Semiterm.Operator.val,
            Semiterm.Operator.One.term_eq, Semiterm.val_func]
          congr 1
          funext i
          exact i.elim0
        _ = (1 : M) := Structure.One.one
          (L := DynamicTruthTemplateFormula.SourceLanguage) (M := M)
    add := by
      intro a b
      change Structure.func
        (L := DynamicTruthTemplateFormula.SourceLanguage)
        (Sum.inl Language.Add.add) ![a, b] = a + b
      exact Structure.Add.add
        (L := DynamicTruthTemplateFormula.SourceLanguage) (M := M) a b
    mul := by
      intro a b
      change Structure.func
        (L := DynamicTruthTemplateFormula.SourceLanguage)
        (Sum.inl Language.Mul.mul) ![a, b] = a * b
      exact Structure.Mul.mul
        (L := DynamicTruthTemplateFormula.SourceLanguage) (M := M) a b
    eq := by
      intro a b
      change Structure.rel
        (L := DynamicTruthTemplateFormula.SourceLanguage)
        (Sum.inl Language.Eq.eq) ![a, b] ↔ a = b
      exact Structure.Eq.eq
        (L := DynamicTruthTemplateFormula.SourceLanguage) (M := M) a b
    lt := by
      intro a b
      change Structure.rel
        (L := DynamicTruthTemplateFormula.SourceLanguage)
        (Sum.inl Language.LT.lt) ![a, b] ↔ a < b
      exact Structure.LT.lt
        (L := DynamicTruthTemplateFormula.SourceLanguage) (M := M) a b
  }
  exact LO.FirstOrder.Arithmetic.standardModel_unique M
    (sourceStructure.lMap (arithmeticHom 3 2))

local instance : M↓[ℒₒᵣ] ⊧* ISigma 1 := models_of_subtheory hPA

/- The quotient bridge supplies this compatibility equation.  It is kept
explicit here: without it, lifted PA does not identify an arbitrary source
structure's equality relation with Lean equality. -/
variable (hArithmeticReduct :
  sourceStructure.lMap (arithmeticHom 3 2) =
    LO.FirstOrder.Arithmetic.standardModel M)

/-- Interpretation of the one source predicate placeholder. -/
private def sourceLowerRelation (bound free p : M) : Prop :=
  Structure.rel
    (L := DynamicTruthTemplateFormula.SourceLanguage)
    (Sum.inr (Sum.inl PlaceholderRel.predicate)) ![bound, free, p]

/-- Interpretation of either named hierarchy-level constant. -/
private noncomputable def sourceLevel (i : Fin 2) : M :=
  Structure.func
    (L := DynamicTruthTemplateFormula.SourceLanguage)
    (Sum.inr (Sum.inr (ParameterFunc.parameter i))) ![]

/- Evaluation of lifted arithmetic syntax after the source arithmetic
reduct has been identified with the standard structure carried by the
quotient. -/
include hArithmeticReduct in
@[simp] private theorem eval_liftArithmeticFormula
    (p : ArithmeticSemisentence n) (v : Fin n → M) :
    (DynamicTruthTemplateFormula.liftArithmeticFormula p).Evalb
        (M := M) v ↔
      p.Evalb (M := M) v := by
  rw [DynamicTruthTemplateFormula.liftArithmeticFormula,
    Semiformula.eval_lMap]
  exact iff_of_eq <| congrArg
    (fun s : Structure ℒₒᵣ M ↦
      Semiformula.Eval (s := s) v Empty.elim p)
    hArithmeticReduct

/-- Closed simultaneous application has the expected environment semantics.
Using `eval_substs` directly avoids the rewrite-valuations simp loop that
appears when the large successor formula is unfolded all at once. -/
@[simp] private theorem eval_apply₃
    (p : Semisentence DynamicTruthTemplateFormula.SourceLanguage 3)
    (t₀ t₁ t₂ : ClosedSemiterm
      DynamicTruthTemplateFormula.SourceLanguage n)
    (v : Fin n → M) :
    (DynamicTruthTemplateFormula.apply₃ p t₀ t₁ t₂).Evalb
        (M := M) v ↔
      p.Evalb (M := M)
        ![t₀.valb (M := M) v, t₁.valb (M := M) v,
          t₂.valb (M := M) v] := by
  simp [DynamicTruthTemplateFormula.apply₃,
    Semiformula.eval_substs, Function.comp_def]
  apply iff_of_eq
  congr 2
  exact funext_fin3 rfl rfl rfl

@[simp] private theorem eval_apply₂
    (p : Semisentence DynamicTruthTemplateFormula.SourceLanguage 2)
    (t₀ t₁ : ClosedSemiterm
      DynamicTruthTemplateFormula.SourceLanguage n)
    (v : Fin n → M) :
    (DynamicTruthTemplateFormula.apply₂ p t₀ t₁).Evalb
        (M := M) v ↔
      p.Evalb (M := M)
        ![t₀.valb (M := M) v, t₁.valb (M := M) v] := by
  simp [DynamicTruthTemplateFormula.apply₂,
    Semiformula.eval_substs, Function.comp_def]
  apply iff_of_eq
  congr 2
  exact funext_fin2 rfl rfl

@[simp] private theorem eval_apply₅
    (p : Semisentence DynamicTruthTemplateFormula.SourceLanguage 5)
    (t₀ t₁ t₂ t₃ t₄ : ClosedSemiterm
      DynamicTruthTemplateFormula.SourceLanguage n)
    (v : Fin n → M) :
    (DynamicTruthSubstitutionInvariantFormula.apply₅
        p t₀ t₁ t₂ t₃ t₄).Evalb
        (M := M) v ↔
      p.Evalb (M := M)
        ![t₀.valb (M := M) v, t₁.valb (M := M) v,
          t₂.valb (M := M) v, t₃.valb (M := M) v,
          t₄.valb (M := M) v] := by
  simp [DynamicTruthSubstitutionInvariantFormula.apply₅,
    Semiformula.eval_substs, Function.comp_def]
  apply iff_of_eq
  congr 2
  exact funext_fin5 rfl rfl rfl rfl rfl

/-- Evaluation of the opaque source atom without asking the simplifier to
normalize a dependent three-vector under `Structure.rel`. -/
@[simp] private theorem eval_lowerAtom
    (t₀ t₁ t₂ : ClosedSemiterm
      DynamicTruthTemplateFormula.SourceLanguage n)
    (v : Fin n → M) :
    (DynamicTruthTemplateFormula.lowerAtom t₀ t₁ t₂).Evalb
        (M := M) v ↔
      sourceLowerRelation
        (t₀.valb (M := M) v) (t₁.valb (M := M) v)
        (t₂.valb (M := M) v) := by
  change Structure.rel _ (fun i ↦
      FirstOrder.Semiterm.val v Empty.elim (![t₀, t₁, t₂] i)) ↔
    Structure.rel _
      ![t₀.valb (M := M) v, t₁.valb (M := M) v,
        t₂.valb (M := M) v]
  apply iff_of_eq
  congr 1
  exact funext_fin3 rfl rfl rfl

/- The universal-record leaf is the sole branch that invokes the opaque
lower relation.  Isolating it also keeps the five existential binders from
being normalized repeatedly inside record validity. -/
include hArithmeticReduct in
@[simp] private theorem eval_universalRecordBranch (v : Fin 3 → M) :
    DynamicTruthTemplateFormula.universalRecordBranch.Evalb (M := M) v ↔
      ∃ q < recordFormula (v 2),
        recordFormula (v 2) = ^∀ q ∧
          LowerPiTrue sourceLowerRelation (v 0)
            (recordBound (v 2)) (recordFree (v 2))
            (recordFormula (v 2)) := by
  simp [
    DynamicTruthTemplateFormula.universalRecordBranch,
    sourceLowerRelation, LowerPiTrue, UniversalRecordPrefix,
    eval_liftArithmeticFormula hArithmeticReduct,
    eval_lowerAtom, Function.comp_def]
  aesop

/- Direct evaluation of the source record-validity formula. -/
include hArithmeticReduct in
@[simp] private theorem eval_successorRecordValid (v : Fin 2 → M) :
    DynamicTruthTemplateFormula.successorRecordValid.Evalb (M := M) v ↔
      SigmaRecordValid sourceLowerRelation
        (sourceLevel 0) (sourceLevel 1) (v 0) (v 1) := by
  simp [DynamicTruthTemplateFormula.successorRecordValid,
    DynamicTruthTemplateFormula.parameterTerm,
    sourceLevel, SigmaRecordValid, RecordDomain,
    PositiveRecordBranches,
    eval_liftArithmeticFormula hArithmeticReduct,
    eval_apply₂, eval_apply₃,
    eval_universalRecordBranch hArithmeticReduct]
  aesop

/- Direct evaluation of the fixed successor template.  Keeping this as a
focused lemma prevents the main completeness proof from repeatedly reducing
the same deeply nested record syntax below every source quantifier. -/
include hArithmeticReduct in
@[simp] private theorem eval_sourceSuccessorTruthFormula (v : Fin 3 → M) :
    DynamicTruthTemplateFormula.successorTruthFormula.Evalb (M := M) v ↔
      SuccessorTruth sourceLowerRelation (sourceLevel 0) (sourceLevel 1)
        (v 0) (v 1) (v 2) := by
  simp [DynamicTruthTemplateFormula.successorTruthFormula,
    sourceLowerRelation, sourceLevel, SuccessorTruth,
    eval_liftArithmeticFormula hArithmeticReduct,
    eval_apply₂, eval_successorRecordValid hArithmeticReduct]

/- The fixed cross-level field has exactly the semantic shape consumed by
the constructor theorem once all represented graph witnesses are evaluated
in the normalized arithmetic reduct. -/
include hArithmeticReduct in
@[simp] private theorem eval_sourceCrossLevelSentence :
    DynamicTruthCrossLevelFormula.sourceCrossLevelSentence.Evalb
        (M := M) ![] ↔
      ∀ p : M, SuccessorCrossLaws sourceLowerRelation
        (sourceLevel 0) (sourceLevel 1) p := by
  simp [DynamicTruthCrossLevelFormula.sourceCrossLevelSentence,
    DynamicTruthCrossLevelFormula.sourceCrossLevelPredicate,
    DynamicTruthCrossLevelFormula.sourceCrossLevelBody,
    DynamicTruthCrossLevelFormula.sourceSigmaDomain,
    DynamicTruthCrossLevelFormula.sourcePiDomain,
    DynamicTruthCrossLevelFormula.sourceLowerPiTruth,
    DynamicTruthTemplateFormula.parameterTerm,
    sourceLowerRelation, sourceLevel,
    SuccessorCrossLaws, LowerPiTrue,
    eval_liftArithmeticFormula hArithmeticReduct,
    eval_apply₂, eval_apply₃, eval_lowerAtom,
    eval_sourceSuccessorTruthFormula hArithmeticReduct,
    DynamicTruthFormula.isSigmaCode_defined.iff,
    DynamicTruthFormula.isPiCode_defined.iff,
    neg.defined.iff]
  aesop

/- The unary source predicate is exactly the semantic invariant consumed by
the constructor theorem.  This focused normalization keeps the six ambient
quantifiers and the represented substitution graph out of the final
completeness proof. -/
include hArithmeticReduct in
@[simp] private theorem eval_sourceSubstitutionInvariantPredicate (p : M) :
    DynamicTruthSubstitutionInvariantFormula.sourceSubstitutionInvariantPredicate.Evalb
        (M := M) ![p] ↔
      SubstitutionInvariantAt
        (SuccessorTruth sourceLowerRelation (sourceLevel 0) (sourceLevel 1))
        (sourceLevel 0) p := by
  simp [
    DynamicTruthSubstitutionInvariantFormula.sourceSubstitutionInvariantPredicate,
    DynamicTruthSubstitutionInvariantFormula.sourceSubstitutionInvariantBody,
    DynamicTruthSubstitutionInvariantFormula.sourceSemitermVector,
    DynamicTruthSubstitutionInvariantFormula.sourceBoundLength,
    DynamicTruthSubstitutionInvariantFormula.sourceSubstitutionEnvironment,
    DynamicTruthSubstitutionInvariantFormula.sourceSemiformula,
    DynamicTruthSubstitutionInvariantFormula.sourceBoundedDomain,
    DynamicTruthSubstitutionInvariantFormula.sourceSubstitutedTruthWitness,
    DynamicTruthTemplateFormula.parameterTerm,
    SubstitutionInvariantAt, sourceLowerRelation, sourceLevel,
    eval_liftArithmeticFormula hArithmeticReduct,
    eval_apply₂, eval_apply₃, eval_apply₅,
    eval_sourceSuccessorTruthFormula hArithmeticReduct,
    isSubstitutionEnvironment_defined.iff,
    lh_defined.iff, IsSemitermVec.defined.iff,
    IsSemiformula.defined.iff, subst.defined.iff,
    (QuantifierBoundedCode.defined ℒₒᵣ (V := M)).iff]

include hArithmeticReduct in
@[simp] private theorem eval_sourceSubstitutionInvariantPredicate' (v : Fin 1 → M) :
    DynamicTruthSubstitutionInvariantFormula.sourceSubstitutionInvariantPredicate.Evalb
        (M := M) v ↔
      SubstitutionInvariantAt
        (SuccessorTruth sourceLowerRelation (sourceLevel 0) (sourceLevel 1))
        (sourceLevel 0) (v 0) := by
  rw [Matrix.fun_eq_vec_one v]
  exact eval_sourceSubstitutionInvariantPredicate hArithmeticReduct (v 0)

include hArithmeticReduct in
@[simp] private theorem eval_sourcePrefixGuard (v : Fin 2 → M) :
    DynamicTruthSubstitutionInvariantStrongStepSource.sourcePrefixGuard.Evalb
        (M := M) v ↔ v 0 < v 1 := by
  have hguard :
      DynamicTruthSubstitutionInvariantStrongStepSource.sourcePrefixGuard =
        DynamicTruthTemplateFormula.liftArithmeticFormula
          (.rel Language.LT.lt
            ![(#0 : ClosedSemiterm ℒₒᵣ 2),
              (#1 : ClosedSemiterm ℒₒᵣ 2)]) := by
    simp [
      DynamicTruthSubstitutionInvariantStrongStepSource.sourcePrefixGuard,
      DynamicTruthTemplateFormula.liftArithmeticFormula,
      Function.comp_def]
    exact funext_fin2 rfl rfl
  rw [hguard]
  rw [eval_liftArithmeticFormula hArithmeticReduct]
  simp

/- Evaluation of the represented strong-induction prefix. -/
include hArithmeticReduct in
@[simp] private theorem eval_sourceStrongPrefix (p : M) :
    DynamicTruthSubstitutionInvariantStrongStepSource.sourceStrongPrefix.Evalb
        (M := M) ![p] ↔
      ∀ q : M, q < p →
        SubstitutionInvariantAt
          (SuccessorTruth sourceLowerRelation (sourceLevel 0) (sourceLevel 1))
          (sourceLevel 0) q := by
  simp [
    DynamicTruthSubstitutionInvariantStrongStepSource.sourceStrongPrefix,
    Semiformula.eval_substs, Function.comp_def,
    eval_sourcePrefixGuard hArithmeticReduct,
    eval_sourceSubstitutionInvariantPredicate' hArithmeticReduct]

end SourceSemantics

/-! ## Explicit equality congruence at the source boundary -/

/-- The sole opaque relation in the one-predicate source language. -/
def lowerPlaceholderRelation :
    DynamicTruthTemplateFormula.SourceLanguage.Rel 3 :=
  placeholderRelation 3 2

/-- Coordinatewise equality replacement for the lower truth placeholder.

Lifted PA supplies all equality axioms for the arithmetic summand, and the
named parameters are nullary.  This is therefore the one missing equality
axiom needed before quotienting an arbitrary source prestructure. -/
noncomputable def sourceLowerCongruenceSentence :
    Sentence DynamicTruthTemplateFormula.SourceLanguage :=
  placeholderCongruenceSentence 3 2

/-- The sound fixed-source obligation.  Congruence stays a visible
antecedent here; after specialization, represented formula replacement in PA
will discharge it for the inserted model-coded lower formula. -/
noncomputable def sourceCongruentStrongStepSentence :
    Sentence DynamicTruthTemplateFormula.SourceLanguage :=
  Arrow.arrow sourceLowerCongruenceSentence
    DynamicTruthSubstitutionInvariantStrongStepSource.sourceStrongStepSentence

set_option maxHeartbeats 1600000 in
/- Completeness is applied only after quotienting by the explicit placeholder
congruence axiom.  In the resulting canonical model the source arithmetic
reduct is the standard arithmetic structure, so the constructor theorem
applies literally to the normalized source formulas. -/
noncomputable def sourceCongruentStrongStepProof :
    parameterTemplatePeano 3 2 ⊢! sourceCongruentStrongStepSentence := by
  simpa [sourceCongruentStrongStepSentence,
    sourceLowerCongruenceSentence] using
    (complete_underPlaceholderCongruence
      DynamicTruthSubstitutionInvariantStrongStepSource.sourceStrongStepSentence
      (fun X ↦ by
        intro _ _ _ _
        have hArithmeticReduct :=
          sourceArithmeticReduct_eq_standardModel (M := X)
        have hArithmeticPA : X↓[ℒₒᵣ] ⊧* Peano := by
          constructor
          intro sigma hsigma
          rw [← hArithmeticReduct]
          exact Semiformula.models_lMap.mp <|
            (inferInstance :
              X↓[DynamicTruthTemplateFormula.SourceLanguage] ⊧*
                parameterTemplatePeano 3 2).models _
              ⟨sigma, hsigma, rfl⟩
        letI : X↓[ℒₒᵣ] ⊧* Peano := hArithmeticPA
        simp [models_iff,
          DynamicTruthSubstitutionInvariantStrongStepSource.sourceStrongStepSentence]
        intro hcontext p hprefix
        have hcontext' := hcontext
        simp [
          DynamicTruthSubstitutionInvariantStrongStepSource.sourceAvailableContext]
          at hcontext'
        have hcross :=
          (eval_sourceCrossLevelSentence hArithmeticReduct).mp
            hcontext'.2.1
        exact
          (eval_sourceSubstitutionInvariantPredicate
            hArithmeticReduct p).mpr <|
            SuccessorTruth.substitution_strongStep hcross <|
              (eval_sourceStrongPrefix hArithmeticReduct p).mp hprefix))

end LeanProofs.BoundedPAConsistency.DynamicTruthSubstitutionInvariantPositiveRankStrongStepProof
