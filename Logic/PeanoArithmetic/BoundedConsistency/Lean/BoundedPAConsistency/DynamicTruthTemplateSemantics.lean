import BoundedPAConsistency.DynamicTruthTemplateFormula
import BoundedPAConsistency.DynamicTruthCrossLevelStrongStepSource
import BoundedPAConsistency.ModelCodedPredicateEqualityQuotient
import BoundedPAConsistency.FinFunext

/-!
# Semantics of the fixed dynamic-truth source template

Several fixed-source proof compilers use the same expanded language: one
ternary relation placeholder denotes the lower truth predicate and two
nullary symbols denote adjacent hierarchy levels.  This module records the
semantic interpretation once, publicly, so later source proofs do not have to
repeat the delicate reduction of `successorTruthFormula`.

The arithmetic-reduct equation is intentionally an explicit premise.  An
arbitrary first-order structure need not interpret equality canonically; the
quotient completeness bridge supplies precisely this equation before these
lemmas are used.
-/

namespace LeanProofs.BoundedPAConsistency.DynamicTruthTemplateSemantics

open LO FirstOrder
open LO.FirstOrder.Arithmetic
open LO.FirstOrder.Arithmetic.Bootstrapping
open LeanProofs.BoundedPAConsistency.CodedHierarchy
open LeanProofs.BoundedPAConsistency.DynamicTruthFormula
open LeanProofs.BoundedPAConsistency.DynamicTruthTemplateFormula
open LeanProofs.BoundedPAConsistency.DynamicTruthCrossLevelStrongStepSource
open LeanProofs.BoundedPAConsistency.FixedLevelTruth
open LeanProofs.BoundedPAConsistency.ModelCodedPredicateTemplate
open LeanProofs.BoundedPAConsistency.ModelCodedPredicateParameters
open LeanProofs.BoundedPAConsistency.OrientedHierarchy

variable {M : Type*}
variable [sourceStructure : Structure SourceLanguage M]
variable [Nonempty M] [ORingStructure M]
variable [hPA : M↓[ℒₒᵣ] ⊧* Peano]

local instance : M↓[ℒₒᵣ] ⊧* ISigma 1 := models_of_subtheory hPA

omit [Nonempty M] hPA in
/-- In a canonical equality source model, the arithmetic summand is the
standard arithmetic structure generated by the ambient `ORingStructure`.
This is the equation produced by the equality-quotient completeness helper. -/
theorem arithmeticReduct_eq_standardModel
    [Structure.ORing SourceLanguage M] :
    sourceStructure.lMap (arithmeticHom 3 2) =
      LO.FirstOrder.Arithmetic.standardModel M := by
  letI : Structure ℒₒᵣ M :=
    sourceStructure.lMap (arithmeticHom 3 2)
  letI : Structure.ORing ℒₒᵣ M := {
    zero := by
      calc
        (@Semiterm.Operator.Zero.zero ℒₒᵣ _).val ![] =
            (@Semiterm.Operator.Zero.zero SourceLanguage _).val ![] := by
          simp only [Semiterm.Operator.val,
            Semiterm.Operator.Zero.term_eq, Semiterm.val_func]
          congr 1
          funext i
          exact i.elim0
        _ = (0 : M) := Structure.Zero.zero
          (L := SourceLanguage) (M := M)
    one := by
      calc
        (@Semiterm.Operator.One.one ℒₒᵣ _).val ![] =
            (@Semiterm.Operator.One.one SourceLanguage _).val ![] := by
          simp only [Semiterm.Operator.val,
            Semiterm.Operator.One.term_eq, Semiterm.val_func]
          congr 1
          funext i
          exact i.elim0
        _ = (1 : M) := Structure.One.one
          (L := SourceLanguage) (M := M)
    add := by
      intro a b
      change Structure.func (L := SourceLanguage)
        (Sum.inl Language.Add.add) ![a, b] = a + b
      exact Structure.Add.add (L := SourceLanguage) (M := M) a b
    mul := by
      intro a b
      change Structure.func (L := SourceLanguage)
        (Sum.inl Language.Mul.mul) ![a, b] = a * b
      exact Structure.Mul.mul (L := SourceLanguage) (M := M) a b
    eq := by
      intro a b
      change Structure.rel (L := SourceLanguage)
        (Sum.inl Language.Eq.eq) ![a, b] ↔ a = b
      exact Structure.Eq.eq (L := SourceLanguage) (M := M) a b
    lt := by
      intro a b
      change Structure.rel (L := SourceLanguage)
        (Sum.inl Language.LT.lt) ![a, b] ↔ a < b
      exact Structure.LT.lt (L := SourceLanguage) (M := M) a b
  }
  exact LO.FirstOrder.Arithmetic.standardModel_unique M
    (sourceStructure.lMap (arithmeticHom 3 2))

/-- Interpretation of the ternary relation placeholder. -/
def lowerRelation (bound free p : M) : Prop :=
  Structure.rel (L := SourceLanguage)
    (Sum.inr (Sum.inl PlaceholderRel.predicate)) ![bound, free, p]

/-- Interpretation of either named hierarchy-level constant. -/
noncomputable def level (i : Fin 2) : M :=
  Structure.func (L := SourceLanguage)
    (Sum.inr (Sum.inr (ParameterFunc.parameter i))) ![]

variable (hArithmeticReduct :
  sourceStructure.lMap (arithmeticHom 3 2) =
    LO.FirstOrder.Arithmetic.standardModel M)

include hArithmeticReduct in
/-- Evaluation of syntax lifted from the arithmetic summand. -/
@[simp] theorem eval_liftArithmeticFormula
    (p : ArithmeticSemisentence n) (v : Fin n → M) :
    (DynamicTruthTemplateFormula.liftArithmeticFormula p).Evalb
        (M := M) v ↔
      p.Evalb (M := M) v := by
  rw [DynamicTruthTemplateFormula.liftArithmeticFormula,
    Semiformula.eval_lMap]
  exact iff_of_eq <| congrArg
    (fun s : Structure ℒₒᵣ M ↦
      Semiformula.Eval (s := s) v Empty.elim p)
    hArithmeticReduct

/-- Evaluation of simultaneous ternary application. -/
@[simp] theorem eval_apply₃
    (p : Semisentence SourceLanguage 3)
    (t₀ t₁ t₂ : ClosedSemiterm SourceLanguage n)
    (v : Fin n → M) :
    (DynamicTruthTemplateFormula.apply₃ p t₀ t₁ t₂).Evalb
        (M := M) v ↔
      p.Evalb (M := M)
        ![t₀.valb (M := M) v, t₁.valb (M := M) v,
          t₂.valb (M := M) v] := by
  simp [DynamicTruthTemplateFormula.apply₃,
    Semiformula.eval_substs, Function.comp_def]
  apply iff_of_eq
  congr 2
  exact funext_fin3 rfl rfl rfl

/-- Evaluation of simultaneous binary application. -/
@[simp] theorem eval_apply₂
    (p : Semisentence SourceLanguage 2)
    (t₀ t₁ : ClosedSemiterm SourceLanguage n)
    (v : Fin n → M) :
    (DynamicTruthTemplateFormula.apply₂ p t₀ t₁).Evalb
        (M := M) v ↔
      p.Evalb (M := M)
        ![t₀.valb (M := M) v, t₁.valb (M := M) v] := by
  simp [DynamicTruthTemplateFormula.apply₂,
    Semiformula.eval_substs, Function.comp_def]
  apply iff_of_eq
  congr 2
  exact funext_fin2 rfl rfl

/-- Evaluation of the opaque lower-truth atom. -/
@[simp] theorem eval_lowerAtom
    (t₀ t₁ t₂ : ClosedSemiterm SourceLanguage n)
    (v : Fin n → M) :
    (DynamicTruthTemplateFormula.lowerAtom t₀ t₁ t₂).Evalb
        (M := M) v ↔
      lowerRelation
        (t₀.valb (M := M) v) (t₁.valb (M := M) v)
        (t₂.valb (M := M) v) := by
  change Structure.rel _ (fun i ↦
      FirstOrder.Semiterm.val v Empty.elim (![t₀, t₁, t₂] i)) ↔
    Structure.rel _
      ![t₀.valb (M := M) v, t₁.valb (M := M) v,
        t₂.valb (M := M) v]
  apply iff_of_eq
  congr 1
  exact funext_fin3 rfl rfl rfl

include hArithmeticReduct in
@[simp] theorem eval_universalRecordBranch (v : Fin 3 → M) :
    DynamicTruthTemplateFormula.universalRecordBranch.Evalb
        (M := M) v ↔
      ∃ q < recordFormula (v 2),
        recordFormula (v 2) = ^∀ q ∧
          LowerPiTrue lowerRelation (v 0)
            (recordBound (v 2)) (recordFree (v 2))
            (recordFormula (v 2)) := by
  simp [DynamicTruthTemplateFormula.universalRecordBranch,
    lowerRelation, LowerPiTrue,
    UniversalRecordPrefix,
    eval_liftArithmeticFormula hArithmeticReduct,
    eval_lowerAtom, Function.comp_def]
  aesop

include hArithmeticReduct in
@[simp] theorem eval_successorRecordValid (v : Fin 2 → M) :
    DynamicTruthTemplateFormula.successorRecordValid.Evalb
        (M := M) v ↔
      SigmaRecordValid lowerRelation (level 0) (level 1) (v 0) (v 1) := by
  simp [DynamicTruthTemplateFormula.successorRecordValid,
    DynamicTruthTemplateFormula.parameterTerm, level,
    SigmaRecordValid, RecordDomain, PositiveRecordBranches,
    eval_liftArithmeticFormula hArithmeticReduct,
    eval_apply₂, eval_apply₃,
    eval_universalRecordBranch hArithmeticReduct]
  aesop

include hArithmeticReduct in
/-- The fixed source formula denotes the semantic successor truth relation. -/
@[simp] theorem eval_successorTruthFormula (v : Fin 3 → M) :
    DynamicTruthTemplateFormula.successorTruthFormula.Evalb
        (M := M) v ↔
      SuccessorTruth lowerRelation (level 0) (level 1)
        (v 0) (v 1) (v 2) := by
  simp [DynamicTruthTemplateFormula.successorTruthFormula,
    lowerRelation, level, SuccessorTruth,
    eval_liftArithmeticFormula hArithmeticReduct,
    eval_apply₂, eval_successorRecordValid hArithmeticReduct]

end LeanProofs.BoundedPAConsistency.DynamicTruthTemplateSemantics
